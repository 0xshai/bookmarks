<script>
  function checkTooltips() {
    document.querySelectorAll<HTMLElement>('.card-wrap').forEach(wrap => {
      const desc = wrap.querySelector<HTMLElement>('.card-desc');
      const tooltip = wrap.querySelector<HTMLElement>('.card-tooltip');
      if (!desc || !tooltip) return;
      // 没有溢出（scrollHeight 不超过 clientHeight）则隐藏浮窗
      if (desc.scrollHeight <= desc.clientHeight + 2) {
        tooltip.dataset.hidden = 'true';
      } else {
        delete tooltip.dataset.hidden;
      }
    });
  }

  // 等字体加载完再判断，避免字体未渲染时尺寸不准
  if (document.fonts) {
    document.fonts.ready.then(checkTooltips);
  } else {
    window.addEventListener('load', checkTooltips);
  }
</script>