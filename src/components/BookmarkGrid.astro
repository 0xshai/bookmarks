---
import { bookmarks } from '../data/bookmarks';
const { category } = Astro.props;
const cat = bookmarks.find(c => c.category === category);
---

{cat && (
  <div class="bookmark-section">
    <p class="section-heading">{cat.category}</p>
    <div class="bookmark-grid">
      {cat.items.map((item) => (
        <div class="card-wrap">
          <a href={item.url} target="_blank" rel="noopener noreferrer" class="bookmark-card">
            <div class="card-header">
              <span class="card-name">{item.name}</span>
              {item.opensource && <span class="badge-oss">开源</span>}
            </div>
            <p class="card-desc">{item.desc}</p>
          </a>
          <div class="card-tooltip">{item.desc}</div>
        </div>
      ))}
    </div>
  </div>
)}

<script>
  function checkTooltips() {
    document.querySelectorAll('.card-desc').forEach(function(desc) {
      var wrap = desc.closest('.card-wrap');
      var tooltip = wrap && wrap.querySelector('.card-tooltip');
      if (!tooltip) return;

      // 用行高算出两行的标准高度
      var lineHeight = parseFloat(getComputedStyle(desc).lineHeight);
      var twoLineHeight = lineHeight * 2;

      // scrollHeight 是完整文字高度（不受 line-clamp 影响）
      // 如果完整高度超过两行，说明有隐藏内容
      if (desc.scrollHeight > twoLineHeight + 4) {
        delete tooltip.dataset.hidden;
      } else {
        tooltip.dataset.hidden = 'true';
      }
    });
  }

  if (document.fonts) {
    document.fonts.ready.then(checkTooltips);
  } else {
    window.addEventListener('load', checkTooltips);
  }
</script>
