---
import '../styles/custom.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>闪光小破站 — 精选工具书签</title>
    <meta name="description" content="精选开源工具与隐私友好资源书签，持续更新。" />
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('starlight-theme') || 'light';
        document.documentElement.setAttribute('data-theme', saved);
      })();
    </script>
    <script defer src="https://cloud.umami.is/script.js" data-website-id="f4a49d2e-86fc-4591-909e-27b5dd86d5f4"></script>
  </head>
  <body>
    <div class="frame">
      <header class="nav">
        <a class="wordmark" href={`${base}/`}>闪光小破站</a>
        <nav class="nav-links">
          <a href={`${base}/bookmarks`}>书签</a>
          <button id="theme-toggle" aria-label="切换主题">
            <svg id="icon-light" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <svg id="icon-dark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </nav>
      </header>

      <main>
        <section class="hero">
          <div class="hero-left">
            <h1>精选工具<br />极客极简</h1>
            <p class="lede">
              收录开源、隐私友好的生产力工具与资源，持续更新。
            </p>
            <div class="cta">
              <a class="btn btn-primary" href={`${base}/bookmarks`}>神奇工具</a>
              <a class="btn btn-secondary" href={`${base}/commands/cheatsheet`}>命令速查</a>
              <a class="btn btn-primary" href={`${base}/tools/losslesscut`}>工具秘籍</a>
              <a class="btn btn-secondary" href={`${base}/tinkering/github-actions-readme`}>折腾记录</a>
              <a class="btn btn-primary" href={`${base}/people/brendan-eich`}>牛人故事</a>
            </div>
          </div>
          <div class="hero-right">
            <canvas id="hero-canvas"></canvas>
          </div>
        </section>

        <section class="features">
          <article class="feature">
            <!-- 精挑细选：钻石切割 + 剔除线 -->
            <svg class="ficon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.2">
              <!-- 钻石轮廓 -->
              <polygon points="24,5 40,18 24,44 8,18" stroke-linejoin="miter"/>
              <!-- 腰线 -->
              <line x1="8" y1="18" x2="40" y2="18"/>
              <!-- 顶部刻面 -->
              <line x1="16" y1="18" x2="24" y2="5"/>
              <line x1="32" y1="18" x2="24" y2="5"/>
              <line x1="12" y1="18" x2="16" y2="11"/>
              <line x1="36" y1="18" x2="32" y2="11"/>
              <!-- 底部刻面 -->
              <line x1="16" y1="18" x2="24" y2="44"/>
              <line x1="32" y1="18" x2="24" y2="44"/>
              <!-- 剔除标记：右上角打叉的小圆 -->
              <circle cx="38" cy="9" r="4.5"/>
              <line x1="35.8" y1="6.8" x2="40.2" y2="11.2" stroke-width="1"/>
              <line x1="40.2" y1="6.8" x2="35.8" y2="11.2" stroke-width="1"/>
            </svg>
            <h2>精挑细选</h2>
            <p>每个分类只保留最实用的工具，有更好的产品就淘汰旧的。</p>
          </article>
          <article class="feature">
            <!-- 隐私优先：六边形盾 + 眼睛划掉 -->
            <svg class="ficon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.2">
              <!-- 六边形盾 -->
              <path d="M24,4 L40,11 L40,27 Q40,38 24,44 Q8,38 8,27 L8,11 Z" stroke-linejoin="round"/>
              <!-- 眼睛轮廓 -->
              <path d="M15,24 Q24,16 33,24 Q24,32 15,24 Z"/>
              <!-- 瞳孔 -->
              <circle cx="24" cy="24" r="3" stroke-width="1"/>
              <!-- 斜杠划掉 -->
              <line x1="15" y1="17" x2="33" y2="31" stroke-width="1.4"/>
            </svg>
            <h2>隐私优先</h2>
            <p>优先推荐开源、本地优先、端到端加密的工具。</p>
          </article>
          <article class="feature">
            <!-- 极客极简：终端提示符 + 光标 -->
            <svg class="ficon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.2">
              <!-- 终端外框 -->
              <rect x="4" y="8" width="40" height="32"/>
              <!-- 顶部栏 -->
              <line x1="4" y1="16" x2="44" y2="16"/>
              <!-- 三个点 -->
              <circle cx="10" cy="12" r="1.5" fill="currentColor" stroke="none"/>
              <circle cx="16" cy="12" r="1.5" fill="currentColor" stroke="none"/>
              <circle cx="22" cy="12" r="1.5" fill="currentColor" stroke="none"/>
              <!-- 提示符 > -->
              <polyline points="10,24 15,27 10,30" stroke-linecap="round" stroke-linejoin="round"/>
              <!-- 命令行文字块 -->
              <line x1="18" y1="27" x2="30" y2="27" stroke-linecap="round"/>
              <!-- 光标 -->
              <rect x="31" y="24" width="4" height="6" fill="currentColor" stroke="none"/>
            </svg>
            <h2>极客极简</h2>
            <p>轻量、高效、无广告，让工具回归工具本身。</p>
          </article>
        </section>
      </main>

      <footer class="foot">
        <span class="foot-mark">shaifx@hotmail.com</span>
        <nav class="foot-links">
          <a href="https://github.com/0xshai/bookmarks/issues/new" target="_blank" rel="noopener noreferrer">推荐工具</a>
        </nav>
      </footer>
    </div>

    <style>
      :global(html) { background: var(--cg-paper); }
      :global(body) { margin: 0; font-family: var(--sl-font); color: var(--cg-ink); overflow-x: hidden; }
      .frame { max-width: 1440px; margin: 0 auto; border: 1px solid var(--cg-rule); }
      .nav { display: flex; align-items: center; justify-content: space-between; padding: 1.1rem 2rem; border-bottom: 1px solid var(--cg-rule); }
      .wordmark { font-weight: 800; font-size: 1.4rem; letter-spacing: -0.035em; color: var(--cg-ink); text-decoration: none; }
      .nav-links { display: flex; align-items: center; gap: 2rem; }
      .nav-links a { color: var(--cg-ink); text-decoration: none; font-size: 0.98rem; }
      .nav-links a:hover { text-decoration: underline; text-underline-offset: 4px; }
      #theme-toggle {
        background: none;
        border: 1px solid var(--cg-rule);
        cursor: pointer;
        padding: 0.4rem 0.5rem;
        color: var(--cg-ink);
        display: flex;
        align-items: center;
        line-height: 0;
      }
      #theme-toggle:hover { background: var(--cg-paper-press); }
      #icon-dark { display: none; }
      .hero { display: grid; grid-template-columns: 1.05fr 0.95fr; border-bottom: 1px solid var(--cg-rule); }
      .hero-left { padding: 4.5rem 3rem 4rem; }
      .hero-right { border-inline-start: 1px solid var(--cg-rule); display: flex; align-items: center; justify-content: center; padding: 0; color: var(--cg-ink); overflow: hidden; }
      #hero-canvas { display: block; width: 100%; height: 100%; min-height: 360px; }
      h1 { font-size: clamp(2.4rem, 6vw, 4.6rem); line-height: 0.98; font-weight: 800; letter-spacing: -0.04em; margin: 0 0 1.6rem; }
      .lede { font-size: 1.18rem; line-height: 1.5; color: var(--cg-ink-2); max-width: 34ch; margin: 0 0 2.2rem; }
      .cta { display: flex; gap: 0.9rem; margin-bottom: 1.6rem; flex-wrap: wrap; }
      .btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.8rem 1.5rem; font-size: 1rem; font-weight: 600; text-decoration: none; border: 1px solid var(--cg-rule); transition: background 0.12s, color 0.12s; }
      .btn-primary { background: var(--cg-ink); color: var(--cg-paper); }
      .btn-primary:hover { background: transparent; color: var(--cg-ink); }
      .btn-secondary { background: transparent; color: var(--cg-ink); }
      .btn-secondary:hover { background: var(--cg-ink); color: var(--cg-paper); }
      .features { display: grid; grid-template-columns: repeat(3, 1fr); }
      .feature { display: grid; grid-template-columns: auto 1px 1fr; column-gap: 1.5rem; align-items: center; padding: 2.6rem 2rem; }
      .feature + .feature { border-inline-start: 1px solid var(--cg-rule); }
      .feature::before { content: ''; grid-column: 2; grid-row: 1/3; align-self: stretch; width: 1px; background: var(--cg-rule); }
      .ficon { grid-column: 1; grid-row: 1/3; width: 56px; height: 56px; color: var(--cg-ink); }
      .feature h2 { grid-column: 3; grid-row: 1; font-size: 1.2rem; font-weight: 700; margin: 0 0 0.5rem; }
      .feature p { grid-column: 3; grid-row: 2; font-size: 0.95rem; line-height: 1.55; color: var(--cg-ink-2); margin: 0; }
      .foot { display: flex; align-items: center; justify-content: space-between; padding: 1.4rem 2rem; border-top: 1px solid var(--cg-rule); }
      .foot-mark { font-weight: 800; letter-spacing: -0.03em; }
      .foot-links { display: flex; gap: 1.6rem; }
      .foot-links a { color: var(--cg-ink-2); text-decoration: none; font-size: 0.92rem; }
      .foot-links a:hover { color: var(--cg-ink); text-decoration: underline; text-underline-offset: 3px; }
      @media (max-width: 860px) {
        .hero { grid-template-columns: 1fr; }
        .hero-right { border-inline-start: none; border-top: 1px solid var(--cg-rule); }
        .features { grid-template-columns: 1fr; }
        .feature + .feature { border-inline-start: none; border-top: 1px solid var(--cg-rule); }
        .nav { padding: 1rem 1.25rem; }
        .hero-left { padding: 2.75rem 1.25rem 2.5rem; }
      }
    </style>

    <script>
      var root = document.documentElement;
      var btn = document.getElementById('theme-toggle');
      var iconLight = document.getElementById('icon-light');
      var iconDark = document.getElementById('icon-dark');

      function applyTheme(theme) {
        root.setAttribute('data-theme', theme);
        localStorage.setItem('starlight-theme', theme);
        iconLight.style.display = theme === 'dark' ? 'none' : 'block';
        iconDark.style.display = theme === 'dark' ? 'block' : 'none';
      }

      var saved = localStorage.getItem('starlight-theme') || 'light';
      applyTheme(saved);

      btn.addEventListener('click', function() {
        applyTheme(root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
      });
    </script>
    <script>
    (function(){
      var canvas = document.getElementById('hero-canvas');
      if(!canvas) return;
      var ctx = canvas.getContext('2d');

      // ── 固定逻辑尺寸（节点坐标在此空间内定义）──
      var LW = 560, LH = 400;

      // ── 真实像素尺寸（跟随容器缩放）──
      var PW, PH, scale;

      function resize(){
        var container = canvas.parentElement;
        PW = container.offsetWidth  || 560;
        PH = container.offsetHeight || 400;
        if(PH < 200) PH = 400;
        var dpr = window.devicePixelRatio || 1;
        canvas.width  = PW * dpr;
        canvas.height = PH * dpr;
        canvas.style.width  = PW + 'px';
        canvas.style.height = PH + 'px';
        ctx.setTransform(1,0,0,1,0,0);
        // 缩放比：保持宽高比，居中放置
        scale = Math.min(PW / LW, PH / LH) * dpr;
        var offX = (PW * dpr - LW * scale) / 2;
        var offY = (PH * dpr - LH * scale) / 2;
        ctx.setTransform(scale, 0, 0, scale, offX, offY);
      }
      resize();
      window.addEventListener('resize', resize);

      // ── 主题颜色：直接读 CSS 变量 ──
      function getP(){
        var dark = document.documentElement.getAttribute('data-theme') === 'dark';
        // 亮色：paper=#f7f6f2  ink=#16150f
        // 暗色：paper=#16150f  ink=#f3f1ea
        return {
          bg:          dark ? '#16150f' : '#f7f6f2',
          grid:        dark ? 'rgba(243,241,234,0.05)' : 'rgba(22,21,15,0.06)',
          nodeBody:    dark ? '#1e1c16' : '#eeecea',
          nodeHead:    dark ? '#2c2a23' : '#dddbd2',
          nodeBorder:  dark ? 'rgba(243,241,234,0.22)' : 'rgba(22,21,15,0.28)',
          nodeHovBody: dark ? '#2a2820' : '#e4e2d8',
          nodeHovBord: dark ? 'rgba(243,241,234,0.7)' : 'rgba(22,21,15,0.75)',
          textHead:    '#ffffff',
          textLabel:   dark ? 'rgba(243,241,234,0.55)' : 'rgba(22,21,15,0.5)',
          textLabelH:  dark ? '#f3f1ea' : '#16150f',
          textMuted:   dark ? 'rgba(243,241,234,0.38)' : 'rgba(22,21,15,0.38)',
          socketOut:   dark ? '#f3f1ea' : '#16150f',
          socketIn:    dark ? '#7c7a70' : '#87847a',
          socketHov:   dark ? '#ffffff' : '#000000',
          wire:        dark ? 'rgba(243,241,234,0.2)' : 'rgba(22,21,15,0.15)',
          wireHov:     dark ? 'rgba(243,241,234,0.75)' : 'rgba(22,21,15,0.7)',
          dot:         dark ? 'rgba(243,241,234,0.65)' : 'rgba(22,21,15,0.5)',
          watermark:   dark ? 'rgba(243,241,234,0.12)' : 'rgba(22,21,15,0.1)',
        };
      }

      // ── 节点定义 ──
      var NODE_W = 148, HEAD_H = 24, ROW_H = 21, SR = 5;

      var defs = [
        { title:'Image Texture',   color:'#3d6b9e', outputs:['Color','Alpha'],           inputs:['Vector'] },
        { title:'Noise Texture',   color:'#5a4ea8', outputs:['Color','Fac'],             inputs:['Vector','Scale','Detail'] },
        { title:'Mix Shader',      color:'#2a7a35', outputs:['Shader'],                  inputs:['Fac','Shader 1','Shader 2'] },
        { title:'Principled BSDF', color:'#8a5a1a', outputs:['BSDF'],                   inputs:['Base Color','Roughness','Metallic'] },
        { title:'Emission',        color:'#993030', outputs:['Emission'],                inputs:['Color','Strength'] },
        { title:'Material Output', color:'#3d5a6b', outputs:[],                          inputs:['Surface','Volume'] },
      ];

      function nodeH(d){ return HEAD_H + Math.max(d.outputs.length, d.inputs.length, 1) * ROW_H + 8; }

      // 固定布局坐标（在 LW×LH 逻辑空间内）
      var layout = [
        { x: 18,  y: 60  },
        { x: 18,  y: 228 },
        { x: 196, y: 148 },
        { x: 196, y: 28  },
        { x: 196, y: 298 },
        { x: 384, y: 165 },
      ];

      var nodes = defs.map(function(d, i){ return { def:d, x:layout[i].x, y:layout[i].y }; });

      var conns = [
        { from:0, oi:0, to:2, ii:1 },
        { from:1, oi:0, to:2, ii:2 },
        { from:1, oi:1, to:3, ii:0 },
        { from:3, oi:0, to:5, ii:0 },
        { from:2, oi:0, to:5, ii:0 },
        { from:4, oi:0, to:5, ii:0 },
        { from:0, oi:1, to:3, ii:2 },
      ];

      var dotPhases = conns.map(function(){ return { p: Math.random(), s: 0.28 + Math.random()*0.18 }; });

      function spPos(n, type, idx){
        var rowsY = HEAD_H + 4 + idx * ROW_H + ROW_H/2;
        return {
          x: type==='out' ? n.x + NODE_W : n.x,
          y: n.y + rowsY
        };
      }

      // ── 鼠标（转换回逻辑坐标）──
      var mouse = { x:-9999, y:-9999 };
      var hovNode = -1, hovSock = null;

      canvas.addEventListener('mousemove', function(e){
        var r = canvas.getBoundingClientRect();
        var cx = (e.clientX - r.left) * (canvas.width  / r.width);
        var cy = (e.clientY - r.top)  * (canvas.height / r.height);
        var offX = (canvas.width  - LW * scale) / 2;
        var offY = (canvas.height - LH * scale) / 2;
        mouse.x = (cx - offX) / scale;
        mouse.y = (cy - offY) / scale;
        updateHover();
      });
      canvas.addEventListener('mouseleave', function(){ mouse.x=-9999; mouse.y=-9999; hovNode=-1; hovSock=null; });

      function updateHover(){
        hovNode = -1; hovSock = null;
        for(var i = nodes.length-1; i >= 0; i--){
          var n = nodes[i], h = nodeH(n.def);
          if(mouse.x>=n.x && mouse.x<=n.x+NODE_W && mouse.y>=n.y && mouse.y<=n.y+h){
            hovNode = i; break;
          }
        }
        for(var i=0; i<nodes.length; i++){
          var n = nodes[i];
          for(var oi=0; oi<n.def.outputs.length; oi++){
            var sp = spPos(n,'out',oi);
            var dx=mouse.x-sp.x, dy=mouse.y-sp.y;
            if(dx*dx+dy*dy < (SR+5)*(SR+5)){ hovSock={node:i,type:'out',idx:oi}; return; }
          }
          for(var ii=0; ii<n.def.inputs.length; ii++){
            var sp = spPos(n,'in',ii);
            var dx=mouse.x-sp.x, dy=mouse.y-sp.y;
            if(dx*dx+dy*dy < (SR+5)*(SR+5)){ hovSock={node:i,type:'in',idx:ii}; return; }
          }
        }
      }

      var t = 0;

      function drawGrid(P){
        var step = 26;
        ctx.strokeStyle = P.grid;
        ctx.lineWidth = 0.5;
        for(var x=0; x<LW; x+=step){ ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,LH); ctx.stroke(); }
        for(var y=0; y<LH; y+=step){ ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(LW,y); ctx.stroke(); }
      }

      function drawWire(ax,ay,bx,by, active, di, P){
        var cp = Math.abs(bx-ax)*0.48;
        ctx.beginPath();
        ctx.moveTo(ax,ay);
        ctx.bezierCurveTo(ax+cp,ay, bx-cp,by, bx,by);
        ctx.strokeStyle = active ? P.wireHov : P.wire;
        ctx.lineWidth   = active ? 1.4 : 0.8;
        ctx.stroke();
        // 流动点
        var f = (dotPhases[di].p + t * dotPhases[di].s) % 1;
        var it=1-f;
        var dx = it*it*it*ax + 3*it*it*f*(ax+cp) + 3*it*f*f*(bx-cp) + f*f*f*bx;
        var dy2= it*it*it*ay + 3*it*it*f*ay       + 3*it*f*f*by       + f*f*f*by;
        ctx.beginPath(); ctx.arc(dx, dy2, 2, 0, Math.PI*2);
        ctx.fillStyle = active ? P.socketHov : P.dot;
        ctx.fill();
      }

      function drawNode(n, idx, P){
        var d = n.def;
        var h = nodeH(d);
        var isH = hovNode === idx;

        // 外框
        ctx.fillStyle   = isH ? P.nodeHovBody : P.nodeBody;
        ctx.strokeStyle = isH ? P.nodeHovBord : P.nodeBorder;
        ctx.lineWidth   = isH ? 1.1 : 0.6;
        ctx.fillRect(n.x, n.y, NODE_W, h);
        ctx.strokeRect(n.x, n.y, NODE_W, h);

        // 标题色块
        ctx.fillStyle   = d.color;
        ctx.globalAlpha = 0.88;
        ctx.fillRect(n.x, n.y, NODE_W, HEAD_H);
        ctx.globalAlpha = 1;

        // 标题文字
        ctx.fillStyle    = P.textHead;
        ctx.font         = '500 10px "IBM Plex Mono",monospace';
        ctx.textAlign    = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(d.title, n.x + NODE_W/2, n.y + HEAD_H/2);

        var rows = Math.max(d.outputs.length, d.inputs.length, 1);
        for(var row=0; row<rows; row++){
          // 输出
          if(row < d.outputs.length){
            var sp = spPos(n,'out',row);
            var hs = hovSock && hovSock.node===idx && hovSock.type==='out' && hovSock.idx===row;
            ctx.beginPath(); ctx.arc(sp.x, sp.y, SR, 0, Math.PI*2);
            ctx.fillStyle = hs ? P.socketHov : P.socketOut;
            ctx.fill();
            ctx.strokeStyle = P.nodeBorder; ctx.lineWidth = 0.5; ctx.stroke();
            ctx.fillStyle    = isH ? P.textLabelH : P.textLabel;
            ctx.font         = '400 9px "IBM Plex Mono",monospace';
            ctx.textAlign    = 'right'; ctx.textBaseline = 'middle';
            ctx.fillText(d.outputs[row], sp.x - SR - 5, sp.y);
          }
          // 输入
          if(row < d.inputs.length){
            var sp = spPos(n,'in',row);
            var hs = hovSock && hovSock.node===idx && hovSock.type==='in' && hovSock.idx===row;
            ctx.beginPath(); ctx.arc(sp.x, sp.y, SR, 0, Math.PI*2);
            ctx.fillStyle = hs ? P.socketHov : P.socketIn;
            ctx.fill();
            ctx.strokeStyle = P.nodeBorder; ctx.lineWidth = 0.5; ctx.stroke();
            ctx.fillStyle    = isH ? P.textLabelH : P.textMuted;
            ctx.font         = '400 9px "IBM Plex Mono",monospace';
            ctx.textAlign    = 'left'; ctx.textBaseline = 'middle';
            ctx.fillText(d.inputs[row], sp.x + SR + 5, sp.y);
          }
        }
      }

      function frame(){
        t += 0.012;
        var P = getP();

        // 清空（用 save/restore 绕过 transform）
        ctx.save();
        ctx.setTransform(1,0,0,1,0,0);
        ctx.fillStyle = P.bg;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.restore();

        drawGrid(P);

        // 连线
        for(var ci=0; ci<conns.length; ci++){
          var c = conns[ci];
          var sp1 = spPos(nodes[c.from],'out',c.oi);
          var sp2 = spPos(nodes[c.to],'in',c.ii);
          var active = hovNode===c.from || hovNode===c.to ||
            (hovSock && ((hovSock.node===c.from&&hovSock.type==='out'&&hovSock.idx===c.oi)||
                         (hovSock.node===c.to  &&hovSock.type==='in' &&hovSock.idx===c.ii)));
          drawWire(sp1.x,sp1.y,sp2.x,sp2.y, active, ci, P);
        }

        // 节点
        for(var i=0; i<nodes.length; i++) drawNode(nodes[i], i, P);

        // 水印
        ctx.fillStyle    = P.watermark;
        ctx.font         = '400 9px "IBM Plex Mono",monospace';
        ctx.textAlign    = 'left';
        ctx.textBaseline = 'bottom';
        ctx.fillText('Shader Editor — Material.001', 8, LH - 6);

        requestAnimationFrame(frame);
      }
      frame();
    })();
    </script>
  </body>
</html>
